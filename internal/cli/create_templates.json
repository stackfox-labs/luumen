    {
      "name": "lune-http",
      "description": "Lune runtime template with HTTP client and server examples.",
      "project": {
        "install": {
          "tools": true,
          "packages": false
        },
        "tasks": {
          "dev": [
            "lune run src/http_server.luau"
          ],
          "build": [
            "echo No build step configured for lune-http"
          ],
          "lint": [
            "stylua src"
          ],
          "format": [
            "stylua src"
          ],
          "test": [
            "echo No test step configured for lune-http"
          ],
          "run": [
            "lune run src/main.luau"
          ],
          "http": [
            "lune run src/http_server.luau"
          ]
        }
      },
      "directories": [
        "src"
      ],
      "files": [
        {
          "path": "rokit.toml",
          "contentLines": [
            "[tools]",
            "lune = \"lune-org/lune@0.10.4\"",
            "stylua = \"JohnnyMorganz/StyLua@2.4.0\""
          ]
        },
        {
          "path": "src/main.luau",
          "contentLines": [
            "local net = require(\"@lune/net\")",
            "local serde = require(\"@lune/serde\")",
            "",
            "local response = net.request(\"https://www.google.com\")",
            "print(\"GET ok:\", response.ok)",
            "print(\"Status:\", response.statusCode, response.statusMessage)",
            "",
            "local apiResponse = net.request({",
            "  url = \"https://dummyjson.com/products/add\",",
            "  method = \"POST\",",
            "  headers = { [\"Content-Type\"] = \"application/json\" },",
            "  body = serde.encode(\"json\", {",
            "    title = \"Cool Pencil\"",
            "  })",
            "})",
            "",
            "local product = serde.decode(\"json\", apiResponse.body)",
            "print(\"Created product:\", product.id, \"-\", product.title)"
          ]
        },
        {
          "path": "src/http_server.luau",
          "contentLines": [
            "local net = require(\"@lune/net\")",
            "",
            "print(\"HTTP echo server listening on http://localhost:8080\")",
            "net.serve(8080, function(request)",
            "  return {",
            "    status = 200,",
            "    headers = { [\"Content-Type\"] = \"text/plain\" },",
            "    body = \"Echo:\\n\" .. request.body,",
            "  }",
            "end)"
          ]
        }
      ]
    },
    {
      "name": "lute-guessing",
      "description": "Lute runtime template with a terminal guessing game and argument parsing example.",
      "project": {
        "install": {
          "tools": true,
          "packages": false
        },
        "tasks": {
          "dev": [
            "lute run src/main.luau"
          ],
          "build": [
            "echo No build step configured for lute-guessing"
          ],
          "lint": [
            "stylua src tests"
          ],
          "format": [
            "stylua src tests"
          ],
          "test": [
            "echo No test step configured for lute-guessing"
          ],
          "play": [
            "lute run src/main.luau"
          ],
          "play-50": [
            "lute run src/main.luau --max 50"
          ],
          "check": [
            "lute check src/main.luau"
          ],
          "setup": [
            "lute setup"
          ]
        }
      },
      "directories": [
        "src",
        "tests"
      ],
      "files": [
        {
          "path": "rokit.toml",
          "contentLines": [
            "[tools]",
            "lute = \"luau-lang/lute@1.0.0\"",
            "stylua = \"JohnnyMorganz/StyLua@2.4.0\""
          ]
        },
        {
          "path": "src/main.luau",
          "contentLines": [
            "local io = require(\"@std/io\")",
            "local args = { ... }",
            "",
            "local function getMaxValue(argv)",
            "  if #argv == 2 then",
            "    error(\"Expected a value after --max\")",
            "  elseif #argv < 2 then",
            "    return 100",
            "  end",
            "",
            "  if argv[2] == \"--max\" then",
            "    local value = tonumber(argv[3])",
            "    if value and value > 0 then",
            "      return math.floor(value)",
            "    end",
            "    error(\"Invalid --max value: \" .. tostring(argv[3]))",
            "  end",
            "",
            "  return 100",
            "end",
            "",
            "local maxValue = getMaxValue(args)",
            "local randomNumber = math.random(maxValue)",
            "",
            "print(`Guess a number between 1 and {maxValue}!`)",
            "",
            "local guessedRight = false",
            "while not guessedRight do",
            "  print(\"Guess a number:\")",
            "  local input = io.input()",
            "  local guess = tonumber(input)",
            "",
            "  if not guess then",
            "    print(`Not a number: {input}`)",
            "    continue",
            "  end",
            "",
            "  if guess > randomNumber then",
            "    print(\"Too high!\")",
            "  elseif guess < randomNumber then",
            "    print(\"Too low!\")",
            "  else",
            "    print(\"Got it!\")",
            "    guessedRight = true",
            "  end",
            "end"
          ]
        },
        {
          "path": ".luaurc",
          "contentLines": [
            "{",
            "  \"languageMode\": \"strict\"",
            "}"
          ]
        },
        {
          "path": "tests/.gitkeep",
          "contentLines": [
            ""
          ]
        }
      ]
    }
  ]
}
